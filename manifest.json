{
  "manifest_version": 3,
  "name": "Copy Markdown link",
  "version": "1.0.0",

  "description": "Copy the current page title and the URL as a Markdown link.",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "copy-markdown-link@ile-24556",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {}
  },

  "background": {
    "scripts": ["dist/background.js"]
  },

  "page_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    },
    "show_matches": ["http://*/*", "https://*/*"],
    "default_title": "Copy Markdown link"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ]
}
