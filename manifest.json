{
  "manifest_version": 3,
  "name": "Copy Markdown link",
  "version": "0.1.0",

  "description": "Copy the current page title and the URL as a Markdown link.",

  "icons": {
    "48": "icons/icon-48.png"
  },

  "background": {
    "scripts": ["dist/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"]
    }
  ],

  "page_action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "show_matches": ["http://*/*", "https://*/*"],
    "default_title": "Copy"
  },

  "permissions": ["tabs"]
}
