{
  "manifest_version": 3,
  "name": "Copy Markdown link",
  "version": "0.1.0",

  "description": "Copy the current page title and the URL as a Markdown link.",

  "icons": {
    "48": "icons/icon-48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "copy-markdown-link@ile-24556",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {}
  },

  "background": {
    "scripts": ["dist/background.js"]
  },

  "page_action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "show_matches": ["http://*/*", "https://*/*"],
    "default_title": "Copy"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ]
}
